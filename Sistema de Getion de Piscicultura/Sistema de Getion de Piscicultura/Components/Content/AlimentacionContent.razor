@using Sistema_de_Getion_de_Piscicultura.Modelos
@using Sistema_de_Getion_de_Piscicultura.Servicios
@inject Lotes_Service LotesService
@inject AlimentacionInventario_Service AlimentacionService

<div class="section-container">
  <div>
    <div class="tabs">
      <button type="button" class="tab-button @(_tab == "lista" ? "tab-button--active" : "")" @onclick='() => _tab = "lista"'>Lista</button>
      <button type="button" class="tab-button @(_tab == "registrar" ? "tab-button--active" : "")" @onclick='() => _tab = "registrar"'>Registrar</button>
      <button type="button" class="tab-button @(_tab == "resumen" ? "tab-button--active" : "")" @onclick='() => _tab = "resumen"'>Resumen diario</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_mensaje))
    {
      <div style="@EstiloMensaje">@_mensaje</div>
    }

    @if (_tab == "lista")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Registros recientes</div>
          <div class="card-title">Alimentación por lote/estanque</div>
          <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
              <thead>
                <tr style="background:#eef2ff;color:#111827;">
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Fecha</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Estanque</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Lote</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Tipo de alimento</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Cantidad (kg)</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Horario</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var r in _registrosHoy)
                {
                  var lote = _lotes.FirstOrDefault(x => x.Id == r.LoteId);
                  <tr>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@r.FechaRegistro.ToString("dd/MM/yyyy")</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@ObtenerNombreEstanque(lote?.EstanqueId ?? 0)</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@(lote?.Codigo ?? $"Lote {r.LoteId}")</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@r.TipoAlimento</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@r.CantidadKg.ToString("0.##")</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@r.Horario.ToString(@"hh\:mm")</td>
                  </tr>
                }
                @if (_registrosHoy.Count == 0)
                {
                  <tr><td colspan="6" style="padding:0.75rem;color:#6b7280;">No hay registros hoy.</td></tr>
                }
              </tbody>
            </table>
          </div>
        </article>
      </div>
    }

    @if (_tab == "registrar")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Nuevo registro</div>
          <div class="card-title">Registrar alimentación</div>
          <form class="contact-form">
            <div class="field">
              <label for="ali-lote">Lote</label>
              <select id="ali-lote" @bind="_loteId">
                @foreach (var lote in _lotes)
                {
                  <option value="@lote.Id">@lote.Codigo (@ObtenerNombreEstanque(lote.EstanqueId))</option>
                }
              </select>
            </div>
            <div class="field">
              <label for="ali-fecha">Fecha</label>
              <input id="ali-fecha" type="date" @bind="_fechaRegistro" />
            </div>
            <div class="field">
              <label for="ali-hora">Horario</label>
              <input id="ali-hora" type="time" @bind="_horaRegistro" />
            </div>
            <div class="field">
              <label for="ali-tipo">Tipo de alimento</label>
              <select id="ali-tipo" @bind="_alimentoId">
                @foreach (var alimento in _inventario)
                {
                  <option value="@alimento.Id">@alimento.Nombre (@alimento.StockKg kg)</option>
                }
              </select>
            </div>
            <div class="field">
              <label for="ali-cantidad">Cantidad (kg)</label>
              <input id="ali-cantidad" type="number" min="0.01" step="0.01" @bind="_cantidadKg" />
            </div>
            <div class="field">
              <button class="btn-login" type="button" @onclick="Registrar">Guardar registro</button>
            </div>
          </form>
        </article>
      </div>
    }

    @if (_tab == "resumen")
    {
      <div class="section-grid">
        <article class="card">
          <div class="card-label">Consumo diario</div>
          <div class="card-title">Por estanque</div>
          <ul style="list-style:none;padding-left:0;font-size:0.9rem;color:#4b5563;">
            @foreach (var item in _consumoHoy)
            {
              <li>@ObtenerNombreEstanque(item.EstanqueId) · @item.CantidadKg.ToString("0.##") kg</li>
            }
          </ul>
        </article>
        <article class="card">
          <div class="card-label">Resumen general</div>
          <div class="card-title">Total del día</div>
          <p class="card-text">
            Total alimentado hoy: <strong>@_totalKgHoy.ToString("0.##") kg</strong>.
          </p>
        </article>
      </div>
    }
  </div>
</div>

@code {
  private string _tab = "lista";
  private string _mensaje = string.Empty;
  private bool _esError;

  private List<Lote> _lotes = new();
  private List<InventarioItem> _inventario = new();
  private List<RegistroAlimentacion> _registrosHoy = new();
  private List<ConsumoEstanqueDto> _consumoHoy = new();

  private int _loteId;
  private int _alimentoId;
  private DateTime _fechaRegistro = DateTime.Today;
  private TimeOnly _horaRegistro = new(8, 0);
  private decimal _cantidadKg = 1m;
  private decimal _totalKgHoy;

  protected override void OnInitialized()
  {
    Refrescar();
    if (_lotes.Count > 0) _loteId = _lotes[0].Id;
    if (_inventario.Count > 0) _alimentoId = _inventario[0].Id;
  }

  private void Registrar()
  {
    var r = AlimentacionService.RegistrarAlimentacion(_loteId, _fechaRegistro, _horaRegistro.ToTimeSpan(), _alimentoId, _cantidadKg);
    _mensaje = r.mensaje;
    _esError = !r.exito;
    if (!r.exito) return;
    _cantidadKg = 1m;
    _horaRegistro = new TimeOnly(8, 0);
    Refrescar();
    _tab = "lista";
  }

  private void Refrescar()
  {
    _lotes = LotesService.ObtenerActivos();
    _inventario = AlimentacionService.ObtenerInventario().ToList();
    _registrosHoy = AlimentacionService.ObtenerRegistrosPorFecha(DateTime.Today).ToList();
    _consumoHoy = AlimentacionService.ObtenerConsumoPorEstanque(DateTime.Today).ToList();
    _totalKgHoy = _consumoHoy.Sum(x => x.CantidadKg);
  }

  private static string ObtenerNombreEstanque(int estanqueId)
      => estanqueId switch
      {
        1 => "E-001",
        2 => "E-101",
        3 => "E-205",
        _ => $"E-{estanqueId}"
      };

  private string EstiloMensaje
      => _esError
          ? "margin:0.6rem 0;padding:0.6rem;border-radius:8px;background:#fee2e2;color:#991b1b;font-size:0.9rem;"
          : "margin:0.6rem 0;padding:0.6rem;border-radius:8px;background:#dcfce7;color:#166534;font-size:0.9rem;";
}
