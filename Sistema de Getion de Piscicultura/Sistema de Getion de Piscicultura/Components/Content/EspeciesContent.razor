@using Sistema_de_Getion_de_Piscicultura.Servicios
@inject Catalogos_Service CatalogosService

<div class="section-container">
  <div>
    <div class="tabs">
      <button type="button" class="tab-button @(_tab == "lista" ? "tab-button--active" : "")" @onclick='() => _tab = "lista"'>Lista</button>
      <button type="button" class="tab-button @(_tab == "crear" ? "tab-button--active" : "")" @onclick='() => _tab = "crear"'>Crear</button>
      <button type="button" class="tab-button @(_tab == "editar" ? "tab-button--active" : "")" @onclick='() => _tab = "editar"'>Editar</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_mensaje))
    {
      <div style="@EstiloMensaje">@_mensaje</div>
    }

    @if (_tab == "lista")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Especies configuradas</div>
          <div class="card-title">Parámetros principales</div>
          <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
              <thead>
                <tr style="background:#eef2ff;color:#111827;">
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Especie</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Temp. óptima (°C)</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">pH óptimo</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Oxígeno mín. (mg/L)</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Peso comercial (g)</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Estado</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var e in _especies)
                {
                  <tr>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@e.Nombre</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@($"{e.TempMin:0.##} – {e.TempMax:0.##}")</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@($"{e.PhMin:0.##} – {e.PhMax:0.##}")</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@($"> {e.OxigenoMin:0.##}")</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@($"{e.PesoComercialMin:0.##} – {e.PesoComercialMax:0.##}")</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;color:@(e.Activo ? "#16a34a" : "#f97316");">@(e.Activo ? "Activo" : "Inactivo")</td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        </article>
      </div>
    }

    @if (_tab == "crear")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Nueva especie</div>
          <div class="card-title">Registrar especie</div>
          <form class="contact-form">
            <div class="field">
              <label for="nueva-especie-nombre">Nombre de la especie</label>
              <input id="nueva-especie-nombre" type="text" @bind="_nuevoNombre" placeholder="Ej. Trucha arcoíris" />
            </div>
            <div class="field">
              <label for="nueva-especie-temp-min">Temp. mínima (°C)</label>
              <input id="nueva-especie-temp-min" type="number" step="0.01" @bind="_nuevoTempMin" />
            </div>
            <div class="field">
              <label for="nueva-especie-temp-max">Temp. máxima (°C)</label>
              <input id="nueva-especie-temp-max" type="number" step="0.01" @bind="_nuevoTempMax" />
            </div>
            <div class="field">
              <label for="nueva-especie-ph-min">pH mínimo</label>
              <input id="nueva-especie-ph-min" type="number" step="0.01" @bind="_nuevoPhMin" />
            </div>
            <div class="field">
              <label for="nueva-especie-ph-max">pH máximo</label>
              <input id="nueva-especie-ph-max" type="number" step="0.01" @bind="_nuevoPhMax" />
            </div>
            <div class="field">
              <label for="nueva-especie-oxigeno">Oxígeno mínimo (mg/L)</label>
              <input id="nueva-especie-oxigeno" type="number" min="0" step="0.01" @bind="_nuevoOxigenoMin" />
            </div>
            <div class="field">
              <label for="nueva-especie-peso-min">Peso comercial mínimo (g)</label>
              <input id="nueva-especie-peso-min" type="number" min="0" step="0.01" @bind="_nuevoPesoMin" />
            </div>
            <div class="field">
              <label for="nueva-especie-peso-max">Peso comercial máximo (g)</label>
              <input id="nueva-especie-peso-max" type="number" min="0" step="0.01" @bind="_nuevoPesoMax" />
            </div>
            <div class="field">
              <button class="btn-login" type="button" @onclick="GuardarNueva">Guardar especie</button>
            </div>
          </form>
        </article>
      </div>
    }

    @if (_tab == "editar")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Editar especie</div>
          <div class="card-title">Seleccionar especie</div>
          <form class="contact-form">
            <div class="field">
              <label for="editar-especie">Especie</label>
              <select id="editar-especie" @bind="_editarId" @bind:after="CargarEdicion">
                <option value="0">-- Seleccione --</option>
                @foreach (var e in _especies)
                {
                  <option value="@e.IdEspecie">@e.Nombre</option>
                }
              </select>
            </div>
            <div class="field">
              <label for="editar-especie-nombre">Nombre</label>
              <input id="editar-especie-nombre" type="text" @bind="_editarNombre" />
            </div>
            <div class="field">
              <label for="editar-especie-temp-min">Temp. mínima (°C)</label>
              <input id="editar-especie-temp-min" type="number" step="0.01" @bind="_editarTempMin" />
            </div>
            <div class="field">
              <label for="editar-especie-temp-max">Temp. máxima (°C)</label>
              <input id="editar-especie-temp-max" type="number" step="0.01" @bind="_editarTempMax" />
            </div>
            <div class="field">
              <label for="editar-especie-ph-min">pH mínimo</label>
              <input id="editar-especie-ph-min" type="number" step="0.01" @bind="_editarPhMin" />
            </div>
            <div class="field">
              <label for="editar-especie-ph-max">pH máximo</label>
              <input id="editar-especie-ph-max" type="number" step="0.01" @bind="_editarPhMax" />
            </div>
            <div class="field">
              <label for="editar-especie-oxigeno">Oxígeno mínimo (mg/L)</label>
              <input id="editar-especie-oxigeno" type="number" min="0" step="0.01" @bind="_editarOxigenoMin" />
            </div>
            <div class="field">
              <label for="editar-especie-peso-min">Peso comercial mínimo (g)</label>
              <input id="editar-especie-peso-min" type="number" min="0" step="0.01" @bind="_editarPesoMin" />
            </div>
            <div class="field">
              <label for="editar-especie-peso-max">Peso comercial máximo (g)</label>
              <input id="editar-especie-peso-max" type="number" min="0" step="0.01" @bind="_editarPesoMax" />
            </div>
            <div class="field">
              <button class="btn-login" type="button" @onclick="GuardarEdicion">Guardar cambios</button>
              <button class="btn-login" style="margin-left:0.6rem;background:#991b1b;" type="button" @onclick="DesactivarSeleccionada">Desactivar</button>
            </div>
          </form>
        </article>
      </div>
    }
  </div>
</div>

@code {
  private string _tab = "lista";
  private List<EspecieResumenDto> _especies = new();
  private string _mensaje = string.Empty;
  private bool _esError;

  private string _nuevoNombre = string.Empty;
  private decimal _nuevoTempMin;
  private decimal _nuevoTempMax;
  private decimal _nuevoPhMin;
  private decimal _nuevoPhMax;
  private decimal _nuevoOxigenoMin;
  private decimal _nuevoPesoMin;
  private decimal _nuevoPesoMax;

  private int _editarId;
  private string _editarNombre = string.Empty;
  private decimal _editarTempMin;
  private decimal _editarTempMax;
  private decimal _editarPhMin;
  private decimal _editarPhMax;
  private decimal _editarOxigenoMin;
  private decimal _editarPesoMin;
  private decimal _editarPesoMax;

  protected override void OnInitialized()
  {
    Refrescar();
  }

  private void GuardarNueva()
  {
    try
    {
      var r = CatalogosService.CrearEspecie(_nuevoNombre, _nuevoTempMin, _nuevoTempMax, _nuevoPhMin, _nuevoPhMax, _nuevoOxigenoMin, _nuevoPesoMin, _nuevoPesoMax);
      MostrarMensaje(r.mensaje, !r.exito);
      if (!r.exito) return;

      _nuevoNombre = string.Empty;
      _nuevoTempMin = 0;
      _nuevoTempMax = 0;
      _nuevoPhMin = 0;
      _nuevoPhMax = 0;
      _nuevoOxigenoMin = 0;
      _nuevoPesoMin = 0;
      _nuevoPesoMax = 0;
      Refrescar();
      _tab = "lista";
    }
    catch (Exception ex)
    {
      MostrarMensaje($"Error al crear especie: {ex.Message}", true);
    }
  }

  private void GuardarEdicion()
  {
    try
    {
      var r = CatalogosService.ActualizarEspecie(_editarId, _editarNombre, _editarTempMin, _editarTempMax, _editarPhMin, _editarPhMax, _editarOxigenoMin, _editarPesoMin, _editarPesoMax);
      MostrarMensaje(r.mensaje, !r.exito);
      if (!r.exito) return;
      Refrescar();
      _tab = "lista";
    }
    catch (Exception ex)
    {
      MostrarMensaje($"Error al actualizar especie: {ex.Message}", true);
    }
  }

  private void DesactivarSeleccionada()
  {
    try
    {
      var r = CatalogosService.DesactivarEspecie(_editarId);
      MostrarMensaje(r.mensaje, !r.exito);
      if (!r.exito) return;
      Refrescar();
      _tab = "lista";
    }
    catch (Exception ex)
    {
      MostrarMensaje($"Error al desactivar especie: {ex.Message}", true);
    }
  }

  private void CargarEdicion()
  {
    var x = _especies.FirstOrDefault(s => s.IdEspecie == _editarId);
    if (x is null) return;
    _editarNombre = x.Nombre;
    _editarTempMin = x.TempMin;
    _editarTempMax = x.TempMax;
    _editarPhMin = x.PhMin;
    _editarPhMax = x.PhMax;
    _editarOxigenoMin = x.OxigenoMin;
    _editarPesoMin = x.PesoComercialMin;
    _editarPesoMax = x.PesoComercialMax;
  }

  private void Refrescar()
  {
    _especies = CatalogosService.ObtenerEspecies();
  }

  private void MostrarMensaje(string mensaje, bool esError)
  {
    _mensaje = mensaje;
    _esError = esError;
  }

  private string EstiloMensaje
      => _esError
          ? "margin:0.6rem 0;padding:0.6rem;border-radius:8px;background:#fee2e2;color:#991b1b;font-size:0.9rem;"
          : "margin:0.6rem 0;padding:0.6rem;border-radius:8px;background:#dcfce7;color:#166534;font-size:0.9rem;";
}
