@using Sistema_de_Getion_de_Piscicultura.Servicios
@inject Catalogos_Service CatalogosService

<div class="section-container">
  <div>
    <div class="tabs">
      <button type="button" class="tab-button @(_tab == "lista" ? "tab-button--active" : "")" @onclick='() => _tab = "lista"'>Lista</button>
      <button type="button" class="tab-button @(_tab == "crear" ? "tab-button--active" : "")" @onclick='() => _tab = "crear"'>Crear</button>
      <button type="button" class="tab-button @(_tab == "editar" ? "tab-button--active" : "")" @onclick='() => _tab = "editar"'>Editar / Desactivar</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_mensaje))
    {
      <div style="@EstiloMensaje">@_mensaje</div>
    }

    @if (_tab == "lista")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Estanques registrados</div>
          <div class="card-title">Vista general</div>
          <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
              <thead>
                <tr style="background:#eef2ff;color:#111827;">
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Código</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Tipo</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Volumen (m³)</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Capacidad máx. peces</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Estado</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var e in _estanques)
                {
                  <tr>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@e.Codigo</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@(string.IsNullOrWhiteSpace(e.Tipo) ? "—" : e.Tipo)</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@(e.VolumenM3?.ToString("0.##") ?? "—")</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@e.CapacidadMaxima.ToString("N0")</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;color:@(e.Activo ? "#16a34a" : "#f97316");">@(e.Estado ?? (e.Activo ? "Activo" : "Inactivo"))</td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        </article>
      </div>
    }

    @if (_tab == "crear")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Nuevo estanque</div>
          <div class="card-title">Registrar estanque</div>
          <form class="contact-form">
            <div class="field">
              <label for="nuevo-estanque-codigo">Código</label>
              <input id="nuevo-estanque-codigo" type="text" @bind="_nuevoCodigo" placeholder="Ej. E-401" />
            </div>
            <div class="field">
              <label for="nuevo-estanque-tipo">Tipo</label>
              <select id="nuevo-estanque-tipo" @bind="_nuevoTipo">
                <option>Pequeño</option>
                <option>Mediano</option>
                <option>Grande</option>
              </select>
            </div>
            <div class="field">
              <label for="nuevo-estanque-volumen">Volumen (m³)</label>
              <input id="nuevo-estanque-volumen" type="number" min="0" step="0.01" @bind="_nuevoVolumenM3" placeholder="Ej. 50" />
            </div>
            <div class="field">
              <label for="nuevo-estanque-capacidad">Capacidad máxima de peces</label>
              <input id="nuevo-estanque-capacidad" type="number" min="1" @bind="_nuevoCapacidadMaxima" placeholder="Ej. 5000" />
            </div>
            <div class="field">
              <label for="nuevo-estanque-estado">Estado</label>
              <select id="nuevo-estanque-estado" @bind="_nuevoEstado">
                <option>Activo</option>
                <option>Inactivo</option>
                <option>Mantenimiento</option>
              </select>
            </div>
            <div class="field">
              <button class="btn-login" type="button" @onclick="GuardarNuevo">Guardar estanque</button>
            </div>
          </form>
        </article>
      </div>
    }

    @if (_tab == "editar")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Editar / desactivar</div>
          <div class="card-title">Seleccionar estanque</div>
          <form class="contact-form">
            <div class="field">
              <label for="editar-estanque-codigo">Estanque</label>
              <select id="editar-estanque-codigo" @bind="_editarId" @bind:after="CargarEdicion">
                <option value="0">-- Seleccione --</option>
                @foreach (var e in _estanques)
                {
                  <option value="@e.IdEstanque">@e.Codigo</option>
                }
              </select>
            </div>
            <div class="field">
              <label for="editar-estanque-tipo">Tipo</label>
              <select id="editar-estanque-tipo" @bind="_editarTipo">
                <option>Pequeño</option>
                <option>Mediano</option>
                <option>Grande</option>
              </select>
            </div>
            <div class="field">
              <label for="editar-estanque-codigo-texto">Código</label>
              <input id="editar-estanque-codigo-texto" type="text" @bind="_editarCodigo" />
            </div>
            <div class="field">
              <label for="editar-estanque-volumen">Volumen (m³)</label>
              <input id="editar-estanque-volumen" type="number" min="0" step="0.01" @bind="_editarVolumenM3" />
            </div>
            <div class="field">
              <label for="editar-estanque-capacidad">Capacidad máxima</label>
              <input id="editar-estanque-capacidad" type="number" min="1" @bind="_editarCapacidadMaxima" />
            </div>
            <div class="field">
              <label for="editar-estanque-estado">Estado</label>
              <select id="editar-estanque-estado" @bind="_editarEstado">
                <option>Activo</option>
                <option>Inactivo</option>
                <option>Mantenimiento</option>
              </select>
            </div>
            <div class="field">
              <button class="btn-login" type="button" @onclick="GuardarEdicion">Guardar cambios</button>
              <button class="btn-login" style="margin-left:0.6rem;background:#991b1b;" type="button" @onclick="DesactivarSeleccionado">Desactivar</button>
            </div>
          </form>
        </article>
      </div>
    }
  </div>
</div>

@code {
  private string _tab = "lista";
  private List<EstanqueResumenDto> _estanques = new();
  private string _mensaje = string.Empty;
  private bool _esError;

  private string _nuevoCodigo = string.Empty;
  private string _nuevoTipo = "Pequeño";
  private decimal? _nuevoVolumenM3;
  private int _nuevoCapacidadMaxima = 1;
  private string _nuevoEstado = "Activo";

  private int _editarId;
  private string _editarCodigo = string.Empty;
  private string _editarTipo = "Pequeño";
  private decimal? _editarVolumenM3;
  private int _editarCapacidadMaxima = 1;
  private string _editarEstado = "Activo";

  protected override void OnInitialized()
  {
    Refrescar();
  }

  private void GuardarNuevo()
  {
    try
    {
      var r = CatalogosService.CrearEstanque(_nuevoCodigo, _nuevoTipo, _nuevoVolumenM3, _nuevoCapacidadMaxima, _nuevoEstado);
      MostrarMensaje(r.mensaje, !r.exito);
      if (!r.exito) return;

      _nuevoCodigo = string.Empty;
      _nuevoTipo = "Pequeño";
      _nuevoVolumenM3 = null;
      _nuevoCapacidadMaxima = 1;
      _nuevoEstado = "Activo";
      Refrescar();
      _tab = "lista";
    }
    catch (Exception ex)
    {
      MostrarMensaje($"Error al crear estanque: {ex.Message}", true);
    }
  }

  private void GuardarEdicion()
  {
    try
    {
      var r = CatalogosService.ActualizarEstanque(_editarId, _editarCodigo, _editarTipo, _editarVolumenM3, _editarCapacidadMaxima, _editarEstado);
      MostrarMensaje(r.mensaje, !r.exito);
      if (!r.exito) return;
      Refrescar();
      _tab = "lista";
    }
    catch (Exception ex)
    {
      MostrarMensaje($"Error al actualizar estanque: {ex.Message}", true);
    }
  }

  private void DesactivarSeleccionado()
  {
    try
    {
      var r = CatalogosService.DesactivarEstanque(_editarId);
      MostrarMensaje(r.mensaje, !r.exito);
      if (!r.exito) return;
      Refrescar();
      _tab = "lista";
    }
    catch (Exception ex)
    {
      MostrarMensaje($"Error al desactivar estanque: {ex.Message}", true);
    }
  }

  private void CargarEdicion()
  {
    var x = _estanques.FirstOrDefault(s => s.IdEstanque == _editarId);
    if (x is null) return;
    _editarCodigo = x.Codigo;
    _editarTipo = string.IsNullOrWhiteSpace(x.Tipo) ? "Pequeño" : x.Tipo!;
    _editarVolumenM3 = x.VolumenM3;
    _editarCapacidadMaxima = x.CapacidadMaxima;
    _editarEstado = string.IsNullOrWhiteSpace(x.Estado) ? (x.Activo ? "Activo" : "Inactivo") : x.Estado!;
  }

  private void Refrescar()
  {
    _estanques = CatalogosService.ObtenerEstanques();
  }

  private void MostrarMensaje(string mensaje, bool esError)
  {
    _mensaje = mensaje;
    _esError = esError;
  }

  private string EstiloMensaje
      => _esError
          ? "margin:0.6rem 0;padding:0.6rem;border-radius:8px;background:#fee2e2;color:#991b1b;font-size:0.9rem;"
          : "margin:0.6rem 0;padding:0.6rem;border-radius:8px;background:#dcfce7;color:#166534;font-size:0.9rem;";
}
