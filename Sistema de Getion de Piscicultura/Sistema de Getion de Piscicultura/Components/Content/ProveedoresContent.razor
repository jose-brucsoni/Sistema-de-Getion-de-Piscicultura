@using Sistema_de_Getion_de_Piscicultura.Servicios
@inject Catalogos_Service CatalogosService

<div class="section-container">
  <div>
    <div class="tabs">
      <button type="button" class="tab-button @(_tab == "lista" ? "tab-button--active" : "")" @onclick='() => _tab = "lista"'>Lista</button>
      <button type="button" class="tab-button @(_tab == "crear" ? "tab-button--active" : "")" @onclick='() => _tab = "crear"'>Crear</button>
      <button type="button" class="tab-button @(_tab == "editar" ? "tab-button--active" : "")" @onclick='() => _tab = "editar"'>Editar</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_mensaje))
    {
      <div style="@EstiloMensaje">@_mensaje</div>
    }

    @if (_tab == "lista")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Proveedores de alevines</div>
          <div class="card-title">Listado actual</div>
          <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
              <thead>
                <tr style="background:#eef2ff;color:#111827;">
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Proveedor</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Contacto</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Certificación sanitaria</th>
                  <th style="text-align:left;padding:0.5rem 0.6rem;border-bottom:1px solid #e5e7eb;">Estado</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var p in _proveedores)
                {
                  <tr>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@p.Nombre</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@(string.IsNullOrWhiteSpace(p.Contacto) ? "—" : p.Contacto)</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;">@(string.IsNullOrWhiteSpace(p.CertificacionSanitaria) ? "—" : p.CertificacionSanitaria)</td>
                    <td style="padding:0.45rem 0.6rem;border-bottom:1px solid #f3f4f6;color:@(p.Activo ? "#16a34a" : "#f97316");">@(p.Activo ? "Activo" : "Inactivo")</td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        </article>
      </div>
    }

    @if (_tab == "crear")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Nuevo proveedor</div>
          <div class="card-title">Registrar proveedor</div>
          <form class="contact-form">
            <div class="field">
              <label for="nuevo-prov-nombre">Nombre del proveedor</label>
              <input id="nuevo-prov-nombre" type="text" @bind="_nuevoNombre" placeholder="Ej. Acuicultura Andina SRL" />
            </div>
            <div class="field">
              <label for="nuevo-prov-contacto">Persona de contacto</label>
              <input id="nuevo-prov-contacto" type="text" @bind="_nuevoContacto" placeholder="Nombre y apellido" />
            </div>
            <div class="field">
              <label for="nuevo-prov-cert">Certificación sanitaria</label>
              <input id="nuevo-prov-cert" type="text" @bind="_nuevoCertificacion" placeholder="Ej. Vigente hasta 12/2026" />
            </div>
            <div class="field">
              <button class="btn-login" type="button" @onclick="GuardarNuevo">Guardar proveedor</button>
            </div>
          </form>
        </article>
      </div>
    }

    @if (_tab == "editar")
    {
      <div class="section-grid">
        <article class="card" style="grid-column: 1 / -1;">
          <div class="card-label">Editar proveedor</div>
          <div class="card-title">Seleccionar proveedor</div>
          <form class="contact-form">
            <div class="field">
              <label for="editar-prov-nombre">Proveedor</label>
              <select id="editar-prov-nombre" @bind="_editarId" @bind:after="CargarEdicion">
                <option value="0">-- Seleccione --</option>
                @foreach (var p in _proveedores)
                {
                  <option value="@p.IdProveedor">@p.Nombre</option>
                }
              </select>
            </div>
            <div class="field">
              <label for="editar-prov-nombre-texto">Nombre</label>
              <input id="editar-prov-nombre-texto" type="text" @bind="_editarNombre" />
            </div>
            <div class="field">
              <label for="editar-prov-contacto">Persona de contacto</label>
              <input id="editar-prov-contacto" type="text" @bind="_editarContacto" />
            </div>
            <div class="field">
              <label for="editar-prov-cert">Certificación sanitaria</label>
              <input id="editar-prov-cert" type="text" @bind="_editarCertificacion" />
            </div>
            <div class="field">
              <button class="btn-login" type="button" @onclick="GuardarEdicion">Guardar cambios</button>
              <button class="btn-login" style="margin-left:0.6rem;background:#991b1b;" type="button" @onclick="DesactivarSeleccionado">Desactivar</button>
            </div>
          </form>
        </article>
      </div>
    }
  </div>
</div>

@code {
  private string _tab = "lista";
  private List<ProveedorResumenDto> _proveedores = new();
  private string _mensaje = string.Empty;
  private bool _esError;

  private string _nuevoNombre = string.Empty;
  private string _nuevoContacto = string.Empty;
  private string _nuevoCertificacion = string.Empty;

  private int _editarId;
  private string _editarNombre = string.Empty;
  private string _editarContacto = string.Empty;
  private string _editarCertificacion = string.Empty;

  protected override void OnInitialized()
  {
    Refrescar();
  }

  private void GuardarNuevo()
  {
    try
    {
      var r = CatalogosService.CrearProveedor(_nuevoNombre, _nuevoContacto, _nuevoCertificacion);
      MostrarMensaje(r.mensaje, !r.exito);
      if (!r.exito) return;

      _nuevoNombre = string.Empty;
      _nuevoContacto = string.Empty;
      _nuevoCertificacion = string.Empty;
      Refrescar();
      _tab = "lista";
    }
    catch (Exception ex)
    {
      MostrarMensaje($"Error al crear proveedor: {ex.Message}", true);
    }
  }

  private void GuardarEdicion()
  {
    try
    {
      var r = CatalogosService.ActualizarProveedor(_editarId, _editarNombre, _editarContacto, _editarCertificacion);
      MostrarMensaje(r.mensaje, !r.exito);
      if (!r.exito) return;
      Refrescar();
      _tab = "lista";
    }
    catch (Exception ex)
    {
      MostrarMensaje($"Error al actualizar proveedor: {ex.Message}", true);
    }
  }

  private void DesactivarSeleccionado()
  {
    try
    {
      var r = CatalogosService.DesactivarProveedor(_editarId);
      MostrarMensaje(r.mensaje, !r.exito);
      if (!r.exito) return;
      Refrescar();
      _tab = "lista";
    }
    catch (Exception ex)
    {
      MostrarMensaje($"Error al desactivar proveedor: {ex.Message}", true);
    }
  }

  private void CargarEdicion()
  {
    var x = _proveedores.FirstOrDefault(p => p.IdProveedor == _editarId);
    if (x is null) return;
    _editarNombre = x.Nombre;
    _editarContacto = x.Contacto ?? string.Empty;
    _editarCertificacion = x.CertificacionSanitaria ?? string.Empty;
  }

  private void Refrescar()
  {
    _proveedores = CatalogosService.ObtenerProveedores();
  }

  private void MostrarMensaje(string mensaje, bool esError)
  {
    _mensaje = mensaje;
    _esError = esError;
  }

  private string EstiloMensaje
      => _esError
          ? "margin:0.6rem 0;padding:0.6rem;border-radius:8px;background:#fee2e2;color:#991b1b;font-size:0.9rem;"
          : "margin:0.6rem 0;padding:0.6rem;border-radius:8px;background:#dcfce7;color:#166534;font-size:0.9rem;";
}
