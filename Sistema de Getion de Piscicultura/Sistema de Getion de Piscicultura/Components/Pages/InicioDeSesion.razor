@page "/inicio-de-sesion"

<PageTitle>Inicio de sesión · Sistema de Piscicultura</PageTitle>

<div class="login-page">
  <div class="section-container login-card">
    <div class="login-logo">
      <img src="/recursos/Iconos/PezSaltando.png" alt="Logo Lagos Andinos" />
    </div>
    <h1 class="section-title" id="login-title">Iniciar sesión</h1>
    <p class="login-subtitle">Accede al Panel de Gestión de Piscicultura.</p>
    <form class="contact-form" id="login-form" novalidate>
      <div class="field">
        <label for="usuario">Usuario</label>
        <input id="usuario" name="usuario" type="text" autocomplete="username" placeholder="Ej. tecnico01" />
      </div>
      <div class="field">
        <label for="password">Contraseña</label>
        <input id="password" name="password" type="password" autocomplete="current-password" placeholder="Ingresa tu contraseña" />
      </div>
      <div class="field">
        <button class="btn-login" type="submit">Entrar al sistema</button>
      </div>
    </form>
  </div>
</div>

